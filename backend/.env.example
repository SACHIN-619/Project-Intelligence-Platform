# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME="Project Impact Intelligence"
APP_VERSION="1.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=true
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Database ─────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pii_db
DATABASE_URL=postgresql+asyncpg://postgres:*******@db.gdpsbnofzckehwbuiqop.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── File Storage ─────────────────────────────────────────────────────────────
# For local dev: files land in /tmp/pii_uploads
# For production: set to cloudflare R2 or S3-compatible
STORAGE_BACKEND=local            # local | s3
STORAGE_LOCAL_PATH=/tmp/pii_uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_ENDPOINT_URL=               # for R2: https://<account>.r2.cloudflarestorage.com

# ─── AI Providers ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash    # free tier model
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.2

# Hugging Face (local inference — no key needed for local models)
HF_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
HF_USE_GPU=false                 # set true if CUDA available

# AI routing thresholds
AI_CONFIDENCE_THRESHOLD=0.60    # below this: ask user, don't recommend
AI_MAX_TOKENS_PER_REQUEST=4000
AI_CACHE_TTL_SECONDS=3600

# ─── Monte Carlo ──────────────────────────────────────────────────────────────
MC_N_SIMULATIONS=1000
MC_OPTIMISTIC_FACTOR=0.8
MC_PESSIMISTIC_FACTOR=1.5

# ─── Risk Engine ──────────────────────────────────────────────────────────────
RISK_THRESHOLD_LOW=3
RISK_THRESHOLD_MEDIUM=6
RISK_THRESHOLD_HIGH=9
RECOVERY_MIN_BENEFIT_DAYS=1

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_RAG_ENABLED=true
FEATURE_MONTE_CARLO_ENABLED=true
FEATURE_PDF_EXPORT_ENABLED=true
FEATURE_WEATHER_AGENT_ENABLED=false   # set true + add weather API key
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
